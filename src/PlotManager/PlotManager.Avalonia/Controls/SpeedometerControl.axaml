<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:PlotManager.Avalonia.ViewModels"
             x:Class="PlotManager.Avalonia.Controls.SpeedometerControl"
             x:DataType="vm:SpeedometerViewModel">
    <Border Background="#2C2C2C" CornerRadius="8" Padding="15" BorderBrush="#444" BorderThickness="1">
        <StackPanel Orientation="Vertical" Spacing="5">
            <TextBlock Text="SPEED GUIDE" Foreground="LightGray" FontWeight="Bold" FontSize="12" HorizontalAlignment="Center"/>
            
            <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,10,0,0">
                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                    <TextBlock Text="TARGET" Foreground="Gray" FontSize="10" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding TargetSpeed, StringFormat={}{0:F1}}" Foreground="Cyan" FontSize="28" FontWeight="Bold"/>
                    <TextBlock Text="km/h" Foreground="Gray" FontSize="10" HorizontalAlignment="Center"/>
                </StackPanel>
                
                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                    <TextBlock Text="CURRENT" Foreground="Gray" FontSize="10" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding CurrentSpeed, StringFormat={}{0:F1}}" Foreground="{Binding SpeedColor}" FontSize="28" FontWeight="Bold"/>
                    <TextBlock Text="km/h" Foreground="Gray" FontSize="10" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>

            <ProgressBar Minimum="0" Maximum="15" Value="{Binding CurrentSpeed}" Height="12" Margin="0,15,0,0"
                         Foreground="{Binding SpeedColor}" Background="#444" CornerRadius="6"/>
        </StackPanel>
    </Border>
</UserControl>
