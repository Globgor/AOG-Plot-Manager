<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mapsui="clr-namespace:Mapsui.UI.Avalonia;assembly=Mapsui.UI.Avalonia"
             xmlns:vm="clr-namespace:PlotManager.Avalonia.ViewModels"
             x:Class="PlotManager.Avalonia.Controls.PlotMapControl"
             x:DataType="vm:MapViewModel">
    <mapsui:MapControl Name="MapControl" Map="{Binding Map}" />
</UserControl>
