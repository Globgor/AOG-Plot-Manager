<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:PlotManager.UI.Views"
             x:Class="PlotManager.UI.Views.WizardNavBar"
             Background="{StaticResource BgSecondaryBrush}"
             Height="64">

    <Border BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="0,0,0,1">
        <Grid ColumnDefinitions="Auto,*,Auto"
              Margin="12,0">

            <!-- Back button -->
            <Button x:Name="BtnBack"
                    Grid.Column="0"
                    Content="← Назад"
                    Classes="secondary"
                    Width="100" Height="34"
                    VerticalAlignment="Center"
                    Click="OnBack" />

            <!-- Step circles (drawn via ItemsControl) -->
            <ItemsControl x:Name="StepsPanel"
                          Grid.Column="1"
                          VerticalAlignment="Center"
                          HorizontalAlignment="Center">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" Spacing="0" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="views:StepItemVm">
                        <!-- Each step item is a StepItem with Circle + Label + line -->
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <!-- Connector line (hidden for first item) -->
                            <Border x:Name="ConnectorLine"
                                    Width="40" Height="2"
                                    VerticalAlignment="Center"
                                    Background="{Binding LineColor}" />
                            <!-- Circle -->
                            <StackPanel Orientation="Vertical"
                                        HorizontalAlignment="Center"
                                        Spacing="2">
                                <Border Width="28" Height="28"
                                        CornerRadius="14"
                                        Background="{Binding CircleBackground}"
                                        HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding Symbol}"
                                               Foreground="{Binding CircleForeground}"
                                               FontSize="11"
                                               FontWeight="Bold"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                </Border>
                                <TextBlock Text="{Binding Label}"
                                           Foreground="{Binding LabelColor}"
                                           FontSize="10"
                                           HorizontalAlignment="Center" />
                            </StackPanel>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Next button -->
            <Button x:Name="BtnNext"
                    Grid.Column="2"
                    Content="Далі →"
                    Classes="accent"
                    Width="120" Height="34"
                    VerticalAlignment="Center"
                    Click="OnNext" />
        </Grid>
    </Border>

</UserControl>
