<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:PlotManager.UI.Views"
        x:Class="PlotManager.UI.Views.MainWindow"
        Title="AOG Plot Manager v0.2.0"
        Width="1280" Height="850"
        MinWidth="960" MinHeight="700"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgPrimaryBrush}">

    <DockPanel>
        <!-- Bottom status bar -->
        <Border DockPanel.Dock="Bottom"
                Background="{StaticResource BgSecondaryBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Height="28">
            <Grid ColumnDefinitions="*,Auto,Auto">
                <TextBlock x:Name="StatusLabel"
                           Grid.Column="0"
                           Text="Ласкаво просимо — оберіть дію для початку"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="11"
                           VerticalAlignment="Center"
                           Margin="12,0" />
                <TextBlock x:Name="HealthLabel"
                           Grid.Column="1"
                           Text="✔ All services healthy"
                           Foreground="{StaticResource AccentGreenBrush}"
                           FontSize="11"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0" />
                <Button x:Name="BtnViewLog"
                        Grid.Column="2"
                        Content="📝 Log"
                        Classes="secondary"
                        Height="22"
                        FontSize="10"
                        Padding="8,2"
                        Margin="0,0,8,0"
                        Click="OnViewLog" />
            </Grid>
        </Border>

        <!-- Top nav bar (hidden on welcome screen) -->
        <views:WizardNavBar x:Name="NavBar"
                            DockPanel.Dock="Top"
                            IsVisible="False"
                            BackRequested="OnBack"
                            NextRequested="OnNext" />

        <!-- Main content area -->
        <ContentControl x:Name="ContentArea"
                        Background="{StaticResource BgPrimaryBrush}" />
    </DockPanel>

</Window>
